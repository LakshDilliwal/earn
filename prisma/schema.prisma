// =============================================================================
// A36 EARN — PRISMA SCHEMA
// Platform: earn.a36labs.com
// DB: MySQL 8.0 (Standard — No PlanetScale, No Edge Runtime)
// =============================================================================

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "ts"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// A36 CORE MODELS
// =============================================================================

/// Promo codes for the A36 commission engine.
/// Admins can create/edit/disable codes via the admin dashboard.
model PromoCode {
  id              String    @id @default(uuid())
  code            String    @unique @db.VarChar(64)
  discountPercent Float     @default(0) // 0-100. 100 = fully waived fee
  description     String?   @db.VarChar(255)
  isActive        Boolean   @default(true)
  maxUses         Int?      // null = unlimited
  useCount        Int       @default(0)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String    // Admin userId

  Bounties Bounties[]
  Grants   Grants[]

  @@index([code, isActive])
  @@index([isActive, expiresAt])
  @@index([createdBy])
}

/// Verified wallet links for Soft KYC.
/// A user can link multiple wallets (Solana + EVM chains).
model UserWallet {
  id            String   @id @default(uuid())
  userId        String
  walletAddress String   @db.VarChar(255)
  chain         WalletChain
  isPrimary     Boolean  @default(false)
  verifiedAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([walletAddress, chain])
  @@index([userId])
  @@index([walletAddress])
  @@index([userId, isPrimary])
}

// =============================================================================
// LISTINGS
// =============================================================================

model Bounties {
  id                 String             @id @default(uuid())
  title              String
  slug               String             @unique
  description        String?            @db.LongText
  deadline           DateTime?
  commitmentDate     DateTime?
  eligibility        Json?
  status             status             @default(OPEN)
  token              String?
  rewardAmount       Float?
  rewards            Json?
  maxBonusSpots      Int                @default(0)
  usdValue           Float?
  tokenUsdAtPublish  Float?
  sponsorId          String
  pocId              String
  source             Source             @default(NATIVE)
  isPublished        Boolean            @default(false)
  isFeatured         Boolean            @default(false)
  isActive           Boolean            @default(true)
  isArchived         Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  applicationLink    String?
  skills             Json?
  type               BountyType         @default(bounty)
  requirements       String?            @db.Text
  isWinnersAnnounced Boolean            @default(false)
  templateId         String?
  region             String             @default("Global")
  pocSocials         String?
  hackathonprize     Boolean            @default(false)
  applicationType    ApplicationType    @default(fixed)
  timeToComplete     String?
  references         Json?
  referredBy         String?
  publishedAt        DateTime?
  isPrivate          Boolean            @default(false)
  agentAccess        AgentAccess        @default(HUMAN_ONLY)
  hackathonId        String?
  compensationType   CompensationType   @default(fixed)
  maxRewardAsk       Float?
  minRewardAsk       Float?
  language           String?
  shouldSendEmail    Boolean            @default(true)
  isFndnPaying       Boolean            @default(false)
  winnersAnnouncedAt DateTime?
  discordMessageIds  Json?
  telegramMessageIds Json?
  ai                 Json?
  publishedBy        String?
  isPro              Boolean            @default(false)
  // --- A36 Commission Fields ---
  feePercent         Float              @default(6) // Platform commission %
  promoCodeId        String?            // Applied promo code (if any)
  feeWaived          Boolean            @default(false) // True if 100% discount
  template           BountiesTemplates? @relation(fields: [templateId], references: [id])
  sponsor            Sponsors           @relation(fields: [sponsorId], references: [id])
  poc                User               @relation("poc", fields: [pocId], references: [id])
  promoCode          PromoCode?         @relation(fields: [promoCodeId], references: [id])
  Submission         Submission[]
  SubscribeBounty    SubscribeBounty[]
  Hackathon          Hackathon?         @relation(fields: [hackathonId], references: [id])
  Scouts             Scouts[]
  Comments           Comment[]

  @@index([id, slug])
  @@index([pocId])
  @@index([templateId])
  @@index([hackathonId])
  @@index([promoCodeId])
  @@index([isPublished, isPrivate])
  @@index([deadline, updatedAt])
  @@index([title])
  @@index([deadline(sort: Asc)], map: "Bounties_deadline_asc_idx")
  @@index([deadline(sort: Desc)], map: "Bounties_deadline_desc_idx")
  @@index([winnersAnnouncedAt(sort: Desc)])
  @@index([isFeatured(sort: Desc)])
  @@index([isPublished, isActive, isArchived, status])
  @@index([isPublished, isActive, isArchived, isPrivate, status])
  @@index([sponsorId, isArchived, isPublished, isActive])
  @@index([isPublished, isActive, isPrivate, hackathonprize])
  @@index([compensationType, usdValue])
  @@index([compensationType, maxRewardAsk])
  @@index([isWinnersAnnounced, isPublished, status])
  @@index([region, isPublished, status])
  @@index([isPublished, isActive, isArchived, isPrivate, type])
  @@index([deadline, isWinnersAnnounced])
  @@index([usdValue, maxRewardAsk])
  @@index([region, isPublished, isActive])
  @@index([sponsorId, isPublished, isActive])
  @@index([isFeatured, deadline])
  @@index([createdAt, isPublished])
  @@index([winnersAnnouncedAt, isWinnersAnnounced])
  @@index([language, compensationType])
  @@index([type, isPublished, isActive, isArchived])
  @@index([isPublished, isActive, isArchived, isPrivate, hackathonprize, type])
  @@index([region, type, isPublished, isActive])
  @@index([deadline, isWinnersAnnounced, type])
}

model BountiesTemplates {
  id               String           @id @default(uuid())
  title            String?
  deadline         DateTime?
  slug             String?
  description      String?          @db.Text
  color            String?
  emoji            String?
  isFeatured       Boolean          @default(false)
  isActive         Boolean          @default(true)
  isArchived       Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  skills           Json?
  type             BountyType       @default(bounty)
  requirements     String?          @db.Text
  region           String           @default("Global")
  applicationType  ApplicationType  @default(fixed)
  status           status           @default(OPEN)
  timeToComplete   String?
  token            String?
  references       Json?
  referredBy       String?
  publishedAt      DateTime?
  compensationType CompensationType @default(fixed)
  maxRewardAsk     Float?
  minRewardAsk     Float?
  language         String?
  rewardAmount     Float?
  rewards          Json?
  maxBonusSpots    Int              @default(0)
  usdValue         Float?
  sponsorId        String
  pocId            String
  pocSocials       String?
  source           Source           @default(NATIVE)
  isPublished      Boolean          @default(false)
  Bounties         Bounties[]
  sponsor          Sponsors         @relation(fields: [sponsorId], references: [id])
  poc              User             @relation("poc", fields: [pocId], references: [id])

  @@index([isActive, isArchived, type])
  @@index([pocId])
  @@index([sponsorId])
  @@index([type])
}

model TokenMetadata {
  id          String   @id @default(uuid())
  tokenName   String   @db.VarChar(191)
  tokenSymbol String   @unique @db.VarChar(64)
  mintAddress String   @unique @db.VarChar(191)
  icon        String   @db.VarChar(2048)
  decimals    Int
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@index([sortOrder])
}

model Grants {
  id                     String             @id @default(uuid())
  title                  String
  slug                   String             @unique
  description            String?            @db.Text
  shortDescription       String?            @db.VarChar(1000)
  token                  String?
  minReward              Float?
  maxReward              Float?
  totalPaid              Float              @default(0)
  historicalApplications Int                @default(0)
  historicalPaid         Float              @default(0)
  link                   String?
  sponsorId              String
  pocId                  String
  isPublished            Boolean            @default(false)
  isFeatured             Boolean            @default(false)
  isActive               Boolean            @default(true)
  isArchived             Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  skills                 Json?
  logo                   String?
  region                 String             @default("Global")
  questions              Json?
  pocSocials             String?
  status                 GrantStatus        @default(OPEN)
  airtableId             String?
  avgResponseTime        String?            @default("24h")
  isNative               Boolean            @default(false)
  isPrivate              Boolean            @default(false)
  references             Json?
  ai                     Json?
  approverRecordId       String?
  emailSender            String?
  replyToEmail           String?
  emailSalutation        String?
  communityLink          String?
  isPro                  Boolean            @default(false)
  // --- A36 Commission Fields ---
  feePercent             Float              @default(6)
  promoCodeId            String?
  feeWaived              Boolean            @default(false)
  sponsor                Sponsors           @relation(fields: [sponsorId], references: [id])
  poc                    User               @relation(fields: [pocId], references: [id])
  promoCode              PromoCode?         @relation(fields: [promoCodeId], references: [id])
  GrantApplication       GrantApplication[]
  GrantTranche           GrantTranche[]

  @@index([id, slug])
  @@index([pocId])
  @@index([promoCodeId])
  @@index([isPublished, isActive, isArchived, status])
  @@index([region, isPublished, isActive])
  @@index([slug])
  @@index([sponsorId, isActive, isArchived, status])
  @@index([createdAt(sort: Desc)])
  @@index([isPublished, isActive, isArchived, isPrivate, status])
  @@index([region, isPublished, isActive, isArchived])
  @@index([sponsorId, isPublished, isActive, isArchived])
  @@index([isFeatured, createdAt])
  @@index([status, isPublished, isActive])
  @@index([region, status, isPublished])
  @@index([minReward, maxReward])
}

model GrantApplication {
  id                  String                 @id @default(uuid())
  userId              String
  grantId             String
  applicationStatus   GrantApplicationStatus @default(Pending)
  projectTitle        String
  projectOneLiner     String
  projectDetails      String                 @db.Text
  projectTimeline     String
  proofOfWork         String                 @db.Text
  walletAddress       String
  twitter             String?
  github              String?
  milestones          String?                @db.Text
  kpi                 String?                @db.Text
  answers             Json?                  @default("[]")
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  label               SubmissionLabels       @default(Pending)
  ask                 Float                  @default(0)
  approvedAmount      Float                  @default(0)
  approvedAmountInUSD Float                  @default(0)
  decidedAt           DateTime?
  totalPaid           Float                  @default(0)
  isShipped           Boolean                @default(false)
  paymentDetails      Json?
  totalTranches       Int                    @default(0)
  like                Json?
  likeCount           Int                    @default(0)
  decidedBy           String?
  notes               String?                @db.VarChar(1000)
  ai                  Json?
  lumaLink            String?
  expenseBreakdown    String?                @db.Text
  user                User                   @relation(fields: [userId], references: [id])
  grant               Grants                 @relation(fields: [grantId], references: [id])
  Comments            Comment[]
  GrantTranche        GrantTranche[]
  CreditLedger        CreditLedger[]

  @@index([likeCount])
  @@index([grantId, userId, applicationStatus])
  @@index([applicationStatus, decidedAt])
  @@index([applicationStatus, createdAt])
  @@index([userId, grantId, createdAt])
  @@index([decidedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([approvedAmountInUSD(sort: Desc)])
}

model GrantTranche {
  id               String             @id @default(uuid())
  applicationId    String
  grantId          String
  ask              Float
  walletAddress    String?
  update           String?            @db.Text
  helpWanted       String?            @db.Text
  status           GrantTrancheStatus @default(Pending)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  approvedAmount   Float?
  decidedAt        DateTime?
  paidAt           DateTime?
  trancheNumber    Int
  eventPictures    Json?
  eventReceipts    Json?
  attendeeCount    Int?
  socialPost       String?            @db.VarChar(500)
  colosseumLink    String?            @db.VarChar(500)
  githubRepo       String?            @db.VarChar(500)
  aiReceipts       Json?
  GrantApplication GrantApplication   @relation(fields: [applicationId], references: [id])
  Grant            Grants             @relation(fields: [grantId], references: [id])

  @@index([applicationId])
  @@index([grantId])
}

model Submission {
  id                 String           @id @default(uuid())
  link               String?          @db.VarChar(500)
  tweet              String?          @db.VarChar(500)
  status             SubmissionStatus @default(Pending)
  eligibilityAnswers Json?            @default("[]")
  userId             String
  agentId            String?
  listingId          String
  isWinner           Boolean          @default(false)
  winnerPosition     Int?
  isActive           Boolean          @default(true)
  isArchived         Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  like               Json?
  likeCount          Int              @default(0)
  isPaid             Boolean          @default(false)
  paymentDetails     Json?
  otherInfo          String?          @db.Text
  ask                Float?
  label              SubmissionLabels @default(Unreviewed)
  rewardInUSD        Float            @default(0)
  ogImage            String?          @db.Text
  notes              String?          @db.VarChar(10000)
  ai                 Json?
  paymentSynced      Boolean          @default(false)
  listing            Bounties         @relation(fields: [listingId], references: [id])
  user               User             @relation(fields: [userId], references: [id])
  agent              Agent?           @relation(fields: [agentId], references: [id])
  Comments           Comment[]
  CreditLedger       CreditLedger[]

  @@index([id, listingId])
  @@index([isWinner])
  @@index([createdAt, isWinner])
  @@index([createdAt, listingId])
  @@index([likeCount])
  @@index([listingId, isActive, isArchived])
  @@index([listingId, userId, isActive, isArchived])
  @@index([listingId, isWinner, isActive, isArchived])
  @@index([userId, listingId, createdAt])
  @@index([userId, isWinner])
  @@index([createdAt(sort: Desc)])
  @@index([likeCount(sort: Desc), createdAt(sort: Desc)])
  @@index([agentId])
}

// =============================================================================
// USER & AUTH
// =============================================================================

model User {
  id                 String               @id @default(uuid())
  publicKey          String?
  walletAddress      String?              // Primary wallet (legacy field, kept for compat)
  email              String               @unique
  username           String?              @unique
  photo              String?              @db.Text
  firstName          String?              @db.VarChar(255)
  lastName           String?              @db.VarChar(255)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  isVerified         Boolean              @default(false)
  role               String               @default("USER")
  isTalentFilled     Boolean              @default(false)
  interests          String?              @db.Text
  bio                String?              @db.Text
  twitter            String?              @db.Text
  discord            String?              @db.Text
  github             String?              @db.Text
  linkedin           String?              @db.Text
  website            String?              @db.Text
  telegram           String?              @db.Text
  community          String?              @db.Text
  experience         String?
  location           String?
  cryptoExperience   String?
  workPrefernce      String?
  currentEmployer    String?
  notifications      Json?
  private            Boolean              @default(false)
  skills             Json?
  currentSponsorId   String?
  emailVerified      DateTime?
  hackathonId        String?
  featureModalShown  Boolean              @default(false)
  surveysShown       Json?
  acceptedTOS        Boolean              @default(false)
  peopleId           String?              @unique
  isBlocked          Boolean              @default(false)
  isKYCVerified      Boolean              @default(false)
  kycName            String?
  kycCountry         String?
  kycAddress         String?
  kycDOB             String?
  kycIDNumber        String?
  kycIDType          String?
  kycVerifiedAt      DateTime?
  blockRationale     String?
  linkedTwitter      Json?
  referralCode       String?              @unique
  referredById       String?
  isPro              Boolean              @default(false)
  isAgent            Boolean              @default(false)
  // --- A36 Soft KYC Trust Score ---
  kycTrustScore      Int                  @default(0) // 0-100 computed from linked socials + wallets
  currentSponsor     Sponsors?            @relation(fields: [currentSponsorId], references: [id])
  people             People?              @relation("UserToPeople", fields: [peopleId], references: [id])
  referredBy         User?                @relation("UserReferrals", fields: [referredById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referrals          User[]               @relation("UserReferrals")
  accounts           Account[]
  sessions           Session[]
  UserSponsors       UserSponsors[]
  poc                Bounties[]           @relation("poc")
  templates          BountiesTemplates[]  @relation("poc")
  Comment            Comment[]
  Submission         Submission[]
  Grants             Grants[]
  UserInvites        UserInvites[]
  SubscribeBounty    SubscribeBounty[]
  PoW                PoW[]
  Hackathon          Hackathon?           @relation(fields: [hackathonId], references: [id])
  emailSettings      EmailSettings[]
  TalentRankings     TalentRankings[]
  Scouts             Scouts[]
  GrantApplication   GrantApplication[]
  SubscribeHackathon SubscribeHackathon[]
  CreditLedger       CreditLedger[]
  telegramUsers      TelegramUser[]
  emailLogs          emailLogs[]
  agentProfile       Agent?
  claimedAgents      Agent[]              @relation("AgentClaimedBy")
  UserWallets        UserWallet[]         // A36 Soft KYC wallet links

  @@index([currentSponsorId])
  @@index([hackathonId])
  @@index([email])
  @@index([username])
  @@index([firstName])
  @@index([lastName])
  @@index([location])
  @@index([referredById])
  @@index([kycTrustScore])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
// SPONSORS, TALENT & COMMUNITY
// =============================================================================

model Sponsors {
  id               String              @id @default(uuid())
  name             String              @unique
  slug             String              @unique
  logo             String?
  url              String?
  industry         String
  twitter          String?
  bio              String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  isArchived       Boolean             @default(false)
  isActive         Boolean             @default(true)
  entityName       String?
  isVerified       Boolean             @default(false)
  isCaution        Boolean             @default(false)
  verificationInfo Json?
  Hackathon        Hackathon?
  UserSponsors     UserSponsors[]
  Bounties         Bounties[]
  Templates        BountiesTemplates[]
  Grants           Grants[]
  User             User[]
  UserInvites      UserInvites[]
  chapter          Chapter?

  @@index([id, slug])
  @@index([isVerified])
  @@index([isCaution, isVerified])
  @@index([isActive, isArchived])
}

model Comment {
  id               String            @id @default(uuid())
  message          String            @db.VarChar(5000)
  authorId         String
  refType          CommentRefType    @default(BOUNTY)
  refId            String
  isActive         Boolean           @default(true)
  isArchived       Boolean           @default(false)
  isPinned         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  replyToId        String?
  submissionId     String?
  type             CommentType       @default(NORMAL)
  author           User              @relation(fields: [authorId], references: [id])
  repliedTo        Comment?          @relation("CommentReplies", fields: [replyToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies          Comment[]         @relation("CommentReplies")
  listing          Bounties?         @relation(fields: [refId], references: [id], map: "Comment_Listing_fkey")
  submission       Submission?       @relation(fields: [refId], references: [id], map: "Comment_Submission_fkey")
  pow              PoW?              @relation(fields: [refId], references: [id], map: "Comment_PoW_fkey")
  GrantApplication GrantApplication? @relation(fields: [refId], references: [id], map: "Comment_GrantApplication_fkey")

  @@index([id, refId])
  @@index([authorId])
  @@index([replyToId])
  @@index([refId, isActive, isArchived, type])
  @@index([refId, isActive, isArchived, replyToId])
  @@index([refType, type])
  @@index([updatedAt(sort: Desc)])
  @@index([refId, isPinned])
}

model Scouts {
  id            String   @id @default(uuid())
  userId        String
  listingId     String
  dollarsEarned Int
  score         Decimal  @db.Decimal(9, 2)
  invited       Boolean
  skills        Json
  createdAt     DateTime @default(now())
  listing       Bounties @relation(fields: [listingId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@unique([userId, listingId])
  @@index([listingId, invited])
  @@index([listingId, score(sort: Desc)])
  @@index([userId, listingId, invited])
  @@index([score(sort: Desc)])
}

model Agent {
  id              String      @id @default(uuid())
  name            String
  userId          String      @unique
  apiKeyHash      String      @unique
  apiKeyPrefix    String
  claimCodeHash   String      @unique
  claimCodePrefix String
  status          AgentStatus @default(ACTIVE)
  claimedByUserId String?
  claimedAt       DateTime?
  lastUsedAt      DateTime?
  metadata        Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id])
  claimedByUser   User?       @relation("AgentClaimedBy", fields: [claimedByUserId], references: [id])
  submissions     Submission[]

  @@index([userId])
  @@index([claimedByUserId])
  @@index([status])
}

model TalentRankings {
  id               String                 @id @default(uuid())
  userId           String
  skill            TalentRankingSkills    @default(ALL)
  timeframe        TalentRankingTimeframe @default(ALL_TIME)
  rank             Int
  submissions      Int                    @default(0)
  winRate          Int                    @default(0)
  wins             Int                    @default(0)
  totalEarnedInUSD Int
  user             User                   @relation(fields: [userId], references: [id])

  @@unique([userId, skill, timeframe])
  @@index([skill, timeframe, rank(sort: Asc)])
  @@index([totalEarnedInUSD(sort: Desc)])
  @@index([rank(sort: Asc)])
  @@index([winRate(sort: Desc)])
}

model PoW {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String    @db.Text
  skills      Json?
  link        String    @db.Text
  createdAt   DateTime  @default(now())
  subSkills   Json?
  updatedAt   DateTime  @updatedAt
  like        Json?
  likeCount   Int       @default(0)
  ogImage     String?   @db.Text
  user        User      @relation(fields: [userId], references: [id])
  Comments    Comment[]

  @@index([createdAt])
  @@index([likeCount])
  @@index([likeCount(sort: Desc), createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, id])
}

model EmailSettings {
  id       Int    @id @default(autoincrement())
  userId   String
  category String
  user     User   @relation(fields: [userId], references: [id])

  @@index([userId, category])
  @@index([category])
}

model UserSponsors {
  userId    String
  sponsorId String
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  sponsor   Sponsors @relation(fields: [sponsorId], references: [id])

  @@id([userId, sponsorId])
  @@index([sponsorId])
}

model UserInvites {
  id         String   @id @default(uuid())
  email      String
  senderId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sponsorId  String
  memberType Role     @default(MEMBER)
  token      String   @unique
  expires    DateTime
  sender     User     @relation(fields: [senderId], references: [id])
  sponsor    Sponsors @relation(fields: [sponsorId], references: [id])

  @@index([senderId])
  @@index([sponsorId])
}

model emailLogs {
  id        String    @id @default(uuid())
  email     String?
  type      EmailType
  bountyId  String?
  userId    String?
  user      User?     @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([bountyId, type])
  @@index([userId, type])
  @@index([type, createdAt(sort: Desc)])
  @@index([email, type])
}

model ResendLogs {
  id        String   @id @default(uuid())
  email     String
  subject   String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([email, status])
}

model SubscribeBounty {
  id         String    @id @default(uuid())
  userId     String
  bountyId   String
  isArchived Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  User       User      @relation(fields: [userId], references: [id])
  Bounties   Bounties? @relation(fields: [bountyId], references: [id])

  @@unique([userId, bountyId])
  @@index([bountyId, isArchived])
  @@index([userId, isArchived])
}

model SubscribeHackathon {
  id          String     @id @default(uuid())
  userId      String
  hackathonId String
  isArchived  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  User        User       @relation(fields: [userId], references: [id])
  Hackthons   Hackathon? @relation(fields: [hackathonId], references: [id])

  @@index([hackathonId])
  @@index([userId])
}

model Hackathon {
  id                 String               @id @default(uuid())
  slug               String               @unique
  name               String
  logo               String
  sponsorId          String?              @unique
  deadline           DateTime?
  startDate          DateTime?
  description        String
  altLogo            String?
  announceDate       DateTime?
  eligibility        Json?
  listings           Bounties[]
  Sponsor            Sponsors?            @relation(fields: [sponsorId], references: [id])
  User               User[]
  SubscribeHackathon SubscribeHackathon[]
}

model UnsubscribedEmail {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model BlockedEmail {
  id        String   @id @default(uuid())
  email     String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

model CreditLedger {
  id             String            @id @default(uuid())
  userId         String
  submissionId   String?
  applicationId  String?
  type           CreditEventType
  change         Int
  effectiveMonth DateTime
  createdAt      DateTime          @default(now())
  decision       SubmissionStatus?
  user           User              @relation(fields: [userId], references: [id])
  submission     Submission?       @relation(fields: [submissionId], references: [id])
  application    GrantApplication? @relation(fields: [applicationId], references: [id])

  @@index([userId])
  @@index([submissionId])
  @@index([applicationId])
  @@index([effectiveMonth])
}

model TelegramUser {
  id           String   @id @default(uuid())
  telegramId   BigInt   @unique
  username     String?
  chatId       BigInt
  isSubscribed Boolean  @default(false)
  isOnboarded  Boolean  @default(false)
  preferences  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isSubscribed])
}

// =============================================================================
// COMMUNITY / CHAPTER (kept for data compat, stripped of Superteam references)
// =============================================================================

model Chapter {
  id              String           @id @default(uuid()) @db.Char(36)
  name            String           @unique @db.VarChar(100)
  slug            String           @unique @db.VarChar(120)
  region          String           @db.VarChar(100)
  displayValue    String?          @db.VarChar(100)
  code            String?          @db.VarChar(40)
  countries       Json?
  memberForm      String?          @db.VarChar(255)
  active          Boolean          @default(true)
  community       String?          @db.VarChar(255)
  pocName         String?          @db.VarChar(255)
  pocEmail        String?          @db.VarChar(255)
  twitterUsername String?          @db.VarChar(100)
  link            String?          @db.VarChar(255)
  icons           String?          @db.Text
  banner          String?          @db.Text
  hello           String?          @db.VarChar(80)
  nationality     String?          @db.VarChar(120)
  airtableBaseId  String?          @db.VarChar(50)
  tgChatId        String?
  tgThreadId      String?
  registeredBy    String?
  sponsorId       String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  welcomeEmailSubject String?      @db.VarChar(255)
  welcomeEmailBody    String?      @db.Text
  sponsor         Sponsors?        @relation(fields: [sponsorId], references: [id])
  people          People[]
  events          Event[]
  jobs            Job[]
  memberInvites   MemberInvite[]

  @@index([region])
}

model MemberInvite {
  id        String    @id @default(uuid()) @db.Char(36)
  email     String
  chapterId String    @db.Char(36)
  invitedBy String    @db.Char(36)
  status    String    @default("pending") @db.VarChar(20)
  token     String?   @unique @db.Char(36)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  chapter   Chapter   @relation(fields: [chapterId], references: [id])

  @@unique([email, chapterId])
  @@index([email])
  @@index([chapterId])
}

model People {
  id               String   @id @default(uuid()) @db.Char(36)
  name             String   @db.VarChar(255)
  email            String?  @db.VarChar(255)
  handle           String?  @db.VarChar(255)
  region           String   @db.VarChar(100)
  chapterId        String?  @db.Char(36)
  type             String?  @db.VarChar(50)
  xUsername        String?  @db.VarChar(100)
  telegram         String?  @db.VarChar(100)
  discord          String?  @db.VarChar(100)
  solWallet        String?  @db.VarChar(50)
  city             String?  @db.VarChar(100)
  skills           String?  @db.Text
  proofOfWork      String?  @db.Text
  bestWorkUrl      String?  @db.VarChar(500)
  source           String   @default("Legacy") @db.VarChar(50)
  airtableRecordId String   @db.VarChar(50)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  jobs             Job[]
  chapter          Chapter? @relation(fields: [chapterId], references: [id])
  user             User?    @relation("UserToPeople")

  @@unique([airtableRecordId])
  @@index([chapterId])
  @@index([email])
  @@index([type, region])
  @@index([type, email])
  @@index([type, name])
  @@index([type, handle])
}

model Event {
  id              String   @id @default(uuid()) @db.Char(36)
  createdAt       DateTime @default(now())
  chapterId       String   @db.Char(36)
  eventTitle      String   @db.VarChar(255)
  eventLumaLink   String?  @db.VarChar(500)
  eventDate       DateTime @db.Date
  eventType       String   @db.VarChar(50)
  eventCategory   String   @db.VarChar(100)
  eventAttendance Int
  isVerified      Int      @default(1)
  lumaEventId     String?  @unique @db.VarChar(100)
  lastSyncedAt    DateTime?
  chapter         Chapter  @relation(fields: [chapterId], references: [id])
}

model Job {
  id          String   @id @default(uuid()) @db.Char(36)
  createdAt   DateTime @default(now())
  chapterId   String   @db.Char(36)
  peopleId    String   @db.Char(36)
  companyName String   @db.VarChar(255)
  roleTitle   String   @db.VarChar(255)
  roleType    String   @db.VarChar(100)
  roleTier    String   @db.VarChar(100)
  salary      Int      @default(0)
  isVerified  Int      @default(1)
  chapter     Chapter  @relation(fields: [chapterId], references: [id])
  people      People   @relation(fields: [peopleId], references: [id])
}

model StatsMessage {
  id        String   @id @default(uuid()) @db.Char(36)
  messageTs String   @db.VarChar(50)
  channelId String   @db.VarChar(50)
  formType  String   @db.VarChar(50)
  recordId  String   @db.Char(36)
  createdAt DateTime @default(now())

  @@unique([messageTs])
}

