    {
      "source": "/hackathon",
      "destination": "https://hackathon.a36labs.com/hackathon"
    },
    {
      "source": "/hackathon/",
      "destination": "https://hackathon.a36labs.com/hackathon/"
    },
    {
      "source": "/hackathon/:path*",
      "destination": "https://hackathon.a36labs.com/hackathon/:path*"
    }
  ]
}
